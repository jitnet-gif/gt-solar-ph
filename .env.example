# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: supabase.com → Project → Settings → API

# Project URL (public, safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Anon/Public key (public, safe to expose)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service Role key — SERVER ONLY, never expose to browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Admin Auth ───────────────────────────────────────────────────────────────
ADMIN_PASSWORD=gtsolar2025
ADMIN_JWT_SECRET=change-me-to-a-secure-random-string-32-chars-min

# ─── Cloudflare Pages ─────────────────────────────────────────────────────────
# Add all of the above in Cloudflare Pages:
# Project → Settings → Environment Variables → Production & Preview
